{
  "info": {
    "_postman_id": "cafeverce-api-collection",
    "name": "CafeVerce API",
    "description": "Postman collection to test the CafeVerce API endpoints, including TV shows, seasons, episodes, movies, and collections.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Google Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"YOUR_GOOGLE_ID_TOKEN_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "google"]
            },
            "description": "Exchanges a Google ID Token (credential) for a CafeVerce JWT access token."
          },
          "response": []
        },
        {
          "name": "Get Profile (Me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Retrieves the active user profile using the CafeVerce JWT token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Media",
      "item": [
        {
          "name": "Import Media (Movie / TV)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"imdbId\": \"tt0944947\",\n  \"contentType\": \"tv\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/media/import",
              "host": ["{{baseUrl}}"],
              "path": ["media", "import"]
            },
            "description": "Imports a movie or TV show using its IMDb ID or TMDB ID."
          },
          "response": []
        },
        {
          "name": "Import Collection",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"collectionId\": 10\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/media/import",
              "host": ["{{baseUrl}}"],
              "path": ["media", "import"]
            },
            "description": "Imports a full collection (e.g. Star Wars, Harry Potter) by TMDB Collection ID."
          },
          "response": []
        },
